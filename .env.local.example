# ── Google OAuth (Gmail) ──────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# The URL Google redirects back to after login
# Local:      http://localhost:3000/api/auth/callback
# Production: https://your-app.vercel.app/api/auth/callback
NEXTAUTH_URL=http://localhost:3000

# Random secret for encrypting session cookies — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=generate_a_random_32_char_string_here

# ── Slack ─────────────────────────────────────────────────────
# Your Slack bot token (xoxb-...) from api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# ── Google Sheet (optional — for writing updates back) ────────
GOOGLE_SHEET_ID=1nWBoNCfhB7qMQrvU6ZKinM3OchHYwV_Pvr44lQylkkk
